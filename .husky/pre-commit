#!/bin/sh
# Mirrors .github/workflows/ci.yml so commits never fail CI.
# Bypass in an emergency with: git commit --no-verify
set -e

cd "$(git rev-parse --show-toplevel)"

say() { printf '\n[pre-commit] %s\n' "$1"; }

# Auto-format staged files (prettier for TS/web, rustfmt for Rust) and re-stage.
say "formatting staged files"
pnpm exec lint-staged

staged="$(git diff --cached --name-only --diff-filter=ACMRD)"

build_frontend() {
  say "TypeScript: build (tsc + vite)"
  pnpm --filter @bioeng/desktop build
}

if printf '%s\n' "$staged" |
  grep -qE '\.(ts|tsx|js|jsx|mjs|cjs|css|html)$|(^|/)(package\.json|tsconfig.*\.json)$|^pnpm-lock\.yaml$'; then
  say "TypeScript: eslint"
  pnpm --filter @bioeng/desktop lint
  build_frontend
fi

if printf '%s\n' "$staged" | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$|(^|/)(rust-toolchain|rustfmt)\.toml$|^(apps/desktop/src-tauri|crates)/'; then
  # tauri::generate_context! embeds the frontend dist at compile time,
  # so the desktop crate cannot build without it.
  if [ ! -d apps/desktop/dist ]; then
    build_frontend
  fi
  say "Rust: clippy"
  cargo clippy --workspace --all-targets --locked -- -D warnings
  say "Rust: tests"
  cargo test --workspace --locked
fi
