{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GG Circuit",
  "mainBinaryName": "gg-circuit",
  "version": "0.1.0",
  "identifier": "org.draggonlab.gg",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GG Circuit",
        "width": 1600,
        "height": 1000,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 23
        },
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "backgroundColor": "#fbfcfa"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["gg"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["runtime/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "GG Circuit"
    }
  }
}
