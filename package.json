{
  "name": "gg",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm desktop:dev",
    "build": "pnpm -r build",
    "desktop:dev": "pnpm --filter @gg/desktop tauri dev",
    "desktop:build": "pnpm --filter @gg/desktop build",
    "desktop:bundle": "pnpm --filter @gg/desktop tauri build",
    "desktop:web:dev": "pnpm --filter @gg/desktop dev",
    "desktop:preview": "pnpm --filter @gg/desktop preview",
    "preview": "pnpm desktop:preview",
    "tauri": "pnpm --filter @gg/desktop tauri",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "postinstall": "scripts/fetch-python-runtime.sh --if-missing"
  },
  "lint-staged": {
    "*.rs": "rustfmt --edition 2021",
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3"
  }
}
